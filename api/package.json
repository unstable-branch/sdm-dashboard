{
  "name": "@sdm/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SDM Dashboard — Hono BFF API server with BullMQ job queue, Drizzle ORM, and Plumber proxy",
  "scripts": {
    "dev": "fuser -k 4000/tcp 2>/dev/null; sleep 1; tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file=.env scripts/seed-admin.ts",
    "db:status": "drizzle-kit status",
    "generate:types": "tsx scripts/generate-plumber-types.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@hono/node-server": "^1.13.0",
    "@sdm/shared": "file:../packages/shared",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.10",
    "drizzle-kit": "^0.28.0",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.0",
    "ioredis": "^5.10.1",
    "nodemailer": "^7.0.13",
    "pg": "^8.21.0",
    "ws": "^8.20.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.7"
  }
}
