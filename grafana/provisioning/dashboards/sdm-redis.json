{
  "title": "SDM Redis Stats",
  "uid": "sdm-redis",
  "version": 1,
  "timezone": "browser",
  "schemaVersion": 39,
  "panels": [
    {
      "title": "Memory Used",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [{ "expr": "redis_memory_used_bytes", "legendFormat": "used" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "min": 0,
        "max": 2147483648
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 536870912 },
              { "color": "orange", "value": 1073741824 },
              { "color": "red", "value": 1610612736 }
            ]
          }
        }
      }
    },
    {
      "title": "Connected Clients",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 0 },
      "targets": [{ "expr": "redis_connected_clients", "legendFormat": "clients" }],
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "title": "Commands/sec",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [{ "expr": "rate(redis_commands_processed_total[5m])", "legendFormat": "ops/s" }]
    },
    {
      "title": "Keyspace Hit Ratio",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "targets": [{ "expr": "rate(redis_keyspace_hits_total[5m]) / (rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m]))", "legendFormat": "hit ratio" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "min": 0,
        "max": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      }
    },
    {
      "title": "Evicted Keys",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "targets": [{ "expr": "redis_evicted_keys_total", "legendFormat": "evicted" }],
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "orange", "value": 1000 },
              { "color": "red", "value": 10000 }
            ]
          }
        }
      }
    }
  ]
}
