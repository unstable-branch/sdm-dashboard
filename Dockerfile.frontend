FROM node:22-alpine@sha256:968df39aedcea65eeb078fb336ed7191baf48f972b4479711397108be0966920 AS builder

RUN apk add --no-cache dumb-init curl bash

RUN npm install -g pnpm@10.30.3

WORKDIR /app

COPY scripts/auto-registry.sh /usr/local/bin/auto-registry.sh
RUN chmod +x /usr/local/bin/auto-registry.sh

ARG PNPM_REGISTRY=
ENV PNPM_REGISTRY=${PNPM_REGISTRY:-https://registry.npmmirror.com}
ENV PNPM_FETCH_TIMEOUT=300000
ENV PNPM_FETCH_RETRIES=5

RUN if [ -z "${PNPM_REGISTRY##*auto*}" ]; then \
        export PNPM_REGISTRY=$(auto-registry.sh); \
    fi

COPY pnpm-workspace.yaml ./
COPY package.json pnpm-lock.yaml* ./
COPY packages/shared/package.json packages/shared/
COPY frontend/package.json frontend/

RUN pnpm install --frozen-lockfile

ARG API_URL=http://api:4000
ENV API_URL=${API_URL}

COPY packages/shared/ packages/shared/
COPY frontend/ frontend/

# If pre-built shared dist exists (from CI artifact), skip rebuild
RUN if [ ! -f packages/shared/dist/index.js ]; then pnpm --filter @sdm/shared build; fi
RUN pnpm --filter @sdm/frontend build

FROM node:22-alpine@sha256:968df39aedcea65eeb078fb336ed7191baf48f972b4479711397108be0966920 AS runner

LABEL org.opencontainers.image.title="SDM Dashboard — Frontend"
LABEL org.opencontainers.image.description="Next.js web application"
LABEL org.opencontainers.image.source="https://github.com/unstable-branch/sdm-dashboard"

RUN apk add --no-cache dumb-init curl

WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
ARG API_URL=http://api:4000
ENV API_URL=${API_URL}

COPY --from=builder /app/frontend/.next/standalone ./
COPY --from=builder /app/frontend/.next/static ./frontend/.next/static
COPY --from=builder /app/frontend/public ./frontend/public

ENV NODE_OPTIONS="--max-old-space-size=2048"

USER node

EXPOSE 3000

CMD ["dumb-init", "node", "frontend/server.js"]
