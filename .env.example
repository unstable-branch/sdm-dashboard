# SDM Dashboard - Production Environment Configuration
# Copy this file to .env and fill in the values

# Database
POSTGRES_PASSWORD=change-me-to-a-strong-password
DATABASE_URL=postgresql://sdm:change-me-to-a-strong-password@postgres:5432/sdm_platform

# JWT Authentication
JWT_SECRET=generate-a-random-string-at-least-32-chars-long

# Internal Hono API to Plumber auth
PLUMBER_INTERNAL_KEY=generate-a-different-random-string-at-least-32-chars-long

# Garage S3 Storage
GARAGE_ACCESS_KEY=your-garage-access-key
GARAGE_SECRET_KEY=your-garage-secret-key

# Grafana
GRAFANA_PASSWORD=admin

# Optional: External Plumber URL (if running separately)
# PLUMBER_URL=http://plumber:8000

# Optional: Redis URL (if using external Redis)
# REDIS_URL=redis://redis:6379

# Optional: Database URL override (if using external Postgres)
# DATABASE_URL=postgresql://sdm:password@postgres:5432/sdm_platform

# Email / SMTP (for password reset)
# Use mailpit in development: SMTP_HOST=localhost, SMTP_PORT=2525 (no auth, UI at port 5000)
# In production, configure your SMTP provider (Gmail, SendGrid, Mailgun, etc.)
SMTP_HOST=localhost
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@sdm-dashboard.local
APP_URL=http://localhost:3000
