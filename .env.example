# SDM Dashboard - Production Environment Configuration
# Copy this file to .env and fill in the values

# Database
POSTGRES_PASSWORD=change-me-to-a-strong-password

# JWT Authentication
JWT_SECRET=generate-a-random-string-at-least-32-chars-long

# Garage S3 Storage
GARAGE_ACCESS_KEY=your-garage-access-key
GARAGE_SECRET_KEY=your-garage-secret-key

# Grafana
GRAFANA_PASSWORD=admin

# Optional: External Plumber URL (if running separately)
# PLUMBER_URL=http://plumber:8000

# Optional: Redis URL (if using external Redis)
# REDIS_URL=redis://redis:6379

# Optional: Database URL (if using external Postgres)
# DATABASE_URL=postgresql://sdm:password@postgres:5432/sdm_platform
