# ═══════════════════════════════════════════════════════════════════════════
# SDM Dashboard — Local Development Environment
#
# ⚠️  THIS FILE CONTAINS INSECURE DEFAULTS FOR LOCAL DEVELOPMENT ONLY.
#     DO NOT use these values in any public or production deployment.
#     Replace every secret before deploying. See PRODUCTION.md for guidance.
# ═══════════════════════════════════════════════════════════════════════════

# Database
# Generate a strong password: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGEME-dev-only-sdm-password
DATABASE_URL=postgresql://sdm:CHANGEME-dev-only-sdm-password@postgres:5432/sdm_platform

# JWT Authentication
# Generate: openssl rand -base64 48
JWT_SECRET=CHANGEME-generate-a-real-secret-openssl-rand-48

# Default admin user (created by migration or pnpm --filter api run db:seed)
#   Email:    admin@sdm.local
#   Password: Admin123!

# Internal Hono API to Plumber auth
# Generate: openssl rand -base64 32
PLUMBER_INTERNAL_KEY=CHANGEME-generate-a-real-key-openssl-rand-32

# Data encryption at rest (AES-256-GCM): 64 hex characters = 32 bytes = 256 bits
# Generate with: openssl rand -hex 32
DATA_ENCRYPTION_KEY=CHANGEME-run-openssl-rand-hex-32-to-generate

# R/Plumber occurrence-file encryption.
# For local beta testing this can match DATA_ENCRYPTION_KEY.
SDM_ENCRYPTION_KEY=CHANGEME-run-openssl-rand-hex-32-to-generate

# Garage S3 Storage
# Generate each with: openssl rand -hex 32
GARAGE_RPC_SECRET=CHANGEME-run-openssl-rand-hex-32
GARAGE_ADMIN_TOKEN=CHANGEME-run-openssl-rand-hex-32
GARAGE_ACCESS_KEY=CHANGEME-run-openssl-rand-hex-32
GARAGE_SECRET_KEY=CHANGEME-run-openssl-rand-hex-32
GARAGE_BUCKET=sdm-artifacts
GARAGE_BUCKET_RASTERS=sdm-artifacts
GARAGE_BUCKET_EXPORTS=sdm-artifacts

# Grafana
# Generate: openssl rand -base64 24
GRAFANA_PASSWORD=CHANGEME-run-openssl-rand-base64-24

# Optional: External Plumber URL (if running separately)
# PLUMBER_URL=http://plumber:8000

# Optional: Redis URL (if using external Redis)
# REDIS_URL=redis://redis:6379

# Optional: Database URL override (if using external Postgres)
# DATABASE_URL=postgresql://sdm:password@postgres:5432/sdm_platform

# Email / SMTP (for password reset)
# Use mailpit in development: SMTP_HOST=localhost, SMTP_PORT=2525 (no auth, UI at port 5000)
# In production, configure your SMTP provider (Gmail, SendGrid, Mailgun, etc.)
SMTP_HOST=localhost
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@sdm-dashboard.local
APP_URL=http://localhost:3000
